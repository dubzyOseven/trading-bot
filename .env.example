# ── MetaAPI ──────────────────────────────────────────────────────────────────
META_API_TOKEN=your_metaapi_token_here
META_API_ACCOUNT_ID=your_mt5_account_id_here

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://trader:secret@db:5432/trading_bot

# ── API Security ──────────────────────────────────────────────────────────────
API_KEY=change_this_to_a_long_random_secret

# ── Trading Defaults ─────────────────────────────────────────────────────────
DEFAULT_SYMBOL=XAUUSD
DEFAULT_TIMEFRAME=1m
DEFAULT_RISK_PERCENT=1.0
DEFAULT_MAX_OPEN_TRADES=3
DEFAULT_ATR_MULTIPLIER_SL=1.5
DEFAULT_ATR_MULTIPLIER_TP=2.5

# ── App ───────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
